{
  "info": {
    "_postman_id": "9a6a2f4c-b8f7-4f75-bbce-2dc46f2f82ea",
    "name": "Mini Food Service - API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Run requests in order from 01 to 12."
  },
  "item": [
    {
      "name": "01 - Get All Foods - 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/foods"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Standard success response', function () {",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body.code).to.eql(200);",
              "  pm.expect(body).to.have.property('timestamp');",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(Array.isArray(body.data)).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Get Food By Id - 200",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/foods/101"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Food detail response valid', function () {",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body.code).to.eql(200);",
              "  pm.expect(body.data).to.be.an('object');",
              "  pm.expect(body.data.id).to.eql(101);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Get Food Not Found - 404",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/foods/{{missingFoodId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function () { pm.response.to.have.status(404); });",
              "const body = pm.response.json();",
              "pm.test('Not found format valid', function () {",
              "  pm.expect(body.success).to.eql(false);",
              "  pm.expect(body.code).to.eql(404);",
              "  pm.expect(body).to.have.property('message');",
              "  pm.expect(body.data).to.be.oneOf([null, undefined]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
