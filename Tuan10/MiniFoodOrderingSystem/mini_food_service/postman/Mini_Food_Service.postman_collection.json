          }
        }
      ]
    },
    {
      "name": "05 - Create Food Unauthorized - 401",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-ROLE", "value": "USER" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Unauthorized Food\",\n  \"price\": 39000,\n  \"description\": \"Should fail because not ADMIN\",\n  \"image\": \"img_url\"\n}"
        },
        "url": "{{baseUrl}}/api/foods"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', function () { pm.response.to.have.status(401); });",
              "const body = pm.response.json();",
              "pm.test('401 format valid', function () {",
              "  pm.expect(body.success).to.eql(false);",
              "  pm.expect(body.code).to.eql(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Create Food Validation Error - 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-ROLE", "value": "{{adminRole}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"price\": 0,\n  \"description\": \"\",\n  \"image\": \"\"\n}"
        },
        "url": "{{baseUrl}}/api/foods"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
              "const body = pm.response.json();",
              "pm.test('Validation error format valid', function () {",
              "  pm.expect(body.success).to.eql(false);",
              "  pm.expect(body.code).to.eql(400);",
              "  pm.expect(body.message).to.eql('Validation Error');",
              "  pm.expect(Array.isArray(body.errors)).to.eql(true);",
              "  pm.expect(body.errors.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Create Food Success - 201",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-ROLE", "value": "{{adminRole}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Test Food\",\n  \"price\": 57000,\n  \"description\": \"Created by Postman runner\",\n  \"image\": \"postman_img\"\n}"
        },
        "url": "{{baseUrl}}/api/foods"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('Create success format valid', function () {",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body.code).to.eql(201);",
              "  pm.expect(body.data).to.be.an('object');",
              "  pm.expect(body.data.id).to.be.a('number');",
              "});",
              "pm.collectionVariables.set('createdFoodId', String(body.data.id));",
              "pm.collectionVariables.set('createdFoodName', body.data.name);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
